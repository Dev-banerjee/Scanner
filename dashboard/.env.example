# ============================================
# VerseScan Dashboard — Environment Variables
# ============================================
# Copy this file to `.env.local` and fill in the values.
#   cp .env.example .env.local
#
# DO NOT commit .env.local — it is git-ignored.
# ============================================

# Supabase — get these from your Supabase project dashboard
# (Settings → API → Project URL & anon/public key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Scanner Backend API URL
# Use http://localhost:8000 for local development
# Use the deployed Render URL for production
NEXT_PUBLIC_API_URL=http://localhost:8000
