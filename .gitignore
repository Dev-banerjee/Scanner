# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ========================
# Dependencies
# ========================
node_modules/
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
venv/

# ========================
# Python
# ========================
__pycache__/
*.py[cod]
*$py.class

# ========================
# Testing
# ========================
/coverage

# ========================
# Next.js / Production
# ========================
.next/
/out/
/build
dist/
build/

# ========================
# Environment Variables
# ========================
# Ignore ALL .env files (they contain secrets)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# EXCEPT .env.example files (safe templates for collaborators)
!.env.example

# ========================
# Generated Reports (PDFs)
# ========================
scanner-engine/report_*.pdf
scanner-engine/final_test_report.pdf

# ========================
# Log / Debug Files
# ========================
scanner-engine/error_log.json
scanner-engine/error_log.txt
scanner-engine/scan_history.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ========================
# OS Files
# ========================
.DS_Store
Thumbs.db
*.pem

# ========================
# Vercel
# ========================
.vercel

# ========================
# TypeScript
# ========================
*.tsbuildinfo
next-env.d.ts

# ========================
# IDEs
# ========================
.vscode/
.idea/
*.swp
*.swo
*~
