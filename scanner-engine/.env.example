# ============================================
# VerseScan Scanner Engine — Environment Variables
# ============================================
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env
#
# DO NOT commit .env — it is git-ignored.
# ============================================

# Supabase — get these from your Supabase project dashboard
# (Settings → API → Project URL & service_role/secret key)
# NOTE: The backend uses the SERVICE ROLE key (not the anon key)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here
